# Database
DATABASE_URL="postgresql://user:password@localhost:5432/supashop?schema=public"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Supabase (if using)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-side for storage uploads (bypasses RLS). Optional — falls back to anon key.
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Bucket that stores payment proof images (create it in Supabase → Storage)
SUPABASE_PROOF_BUCKET=proof-of-payment

# AI (Google Generative AI)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# Environment
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000
